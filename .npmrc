@joshuafolkken:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}

engine-strict=true
minimum-release-age=1440
confirmModulesPurge=false
# pnpm >=11.5 reconstructs npm-style tarball URLs under --frozen-lockfile, which breaks
# private GitHub Packages (non-standard /download/<sha> path) and 401s on clean CI.
# Pinning the full tarball URL in the lockfile avoids the reconstruction. Matches joshuafolkken-com.
lockfile-include-tarball-url=true
