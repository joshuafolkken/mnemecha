{
	"name": "mnemecha",
	"version": "0.107.0",
	"type": "module",
	"private": true,
	"scripts": {
		"preinstall": "pnpm dlx @aikidosec/safe-chain setup-ci",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "pnpm gen && svelte-kit sync",
		"gen": "pnpm gen:pre && wrangler types",
		"gen:pre": "node -e \"const fs=require('node:fs');const d='.svelte-kit/cloudflare';if(fs.existsSync(d))fs.readdirSync(d).forEach(f=>f.startsWith('_worker.')&&fs.rmSync(d+'/'+f,{force:true}))\"",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"postinstall": "lefthook install && tsx node_modules/@joshuafolkken/kit/scripts/fix-gh-packages.ts",
		"josh": "josh",
		"size-limit": "size-limit"
	},
	"dependencies": {
		"@threlte/core": "^8.5.14",
		"@threlte/extras": "^9.17.1",
		"three": "^0.184.0"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@joshuafolkken/kit": "^0.172.0",
		"@playwright/test": "^1.60.0",
		"@size-limit/file": "^12.1.0",
		"@size-limit/preset-app": "^12.1.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25.7.0",
		"@types/three": "^0.184.1",
		"@vite-pwa/sveltekit": "^1.1.0",
		"@vitest/browser-playwright": "^4.1.6",
		"cspell": "^10.0.0",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"lefthook": "^2.1.6",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"rollup-plugin-visualizer": "^7.0.1",
		"size-limit": "^12.1.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3",
		"vite": "^8.0.12",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.6",
		"vitest-browser-svelte": "^2.1.1",
		"workbox-build": "^7.4.1",
		"wrangler": "^4.90.1"
	},
	"packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": ">=11.0.0-0",
			"onFail": "error"
		}
	},
	"size-limit": [
		{
			"path": ".svelte-kit/output/client/_app/immutable/**/*.js",
			"limit": "1000 kB"
		}
	],
	"pnpm": {
		"overrides": {
			"serialize-javascript": ">=7.0.5"
		},
		"onlyBuiltDependencies": [
			"sharp",
			"workerd",
			"esbuild"
		],
		"ignoredBuiltDependencies": [
			"@joshuafolkken/kit",
			"lefthook"
		]
	}
}
