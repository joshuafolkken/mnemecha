{
	"name": "mnemecha",
	"version": "0.120.0",
	"type": "module",
	"private": true,
	"scripts": {
		"preinstall": "pnpm dlx @aikidosec/safe-chain setup-ci",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "pnpm prepare:gen && pnpm prepare:sync && pnpm prepare:lefthook && pnpm prepare:gh-packages",
		"gen": "pnpm gen:pre && wrangler types",
		"gen:pre": "node -e \"const fs=require('node:fs');const d='.svelte-kit/cloudflare';if(fs.existsSync(d))fs.readdirSync(d).forEach(f=>f.startsWith('_worker.')&&fs.rmSync(d+'/'+f,{force:true}))\"",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"josh": "josh",
		"size-limit": "size-limit",
		"prepare:gen": "[ ! -f wrangler.jsonc ] || pnpm gen",
		"prepare:sync": "svelte-kit sync || echo ''",
		"prepare:lefthook": "[ -n \"$CI\" ] || ! command -v lefthook >/dev/null 2>&1 || lefthook install",
		"prepare:gh-packages": "[ -n \"$CI\" ] || ! command -v tsx >/dev/null 2>&1 || tsx node_modules/@joshuafolkken/kit/scripts/fix-gh-packages.ts"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@joshuafolkken/game-kit": "^0.169.0",
		"@joshuafolkken/kit": "^0.282.0",
		"@playwright/test": "^1.60.0",
		"@size-limit/file": "^12.1.0",
		"@size-limit/preset-app": "^12.1.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.65.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.0",
		"@threlte/core": "^8.5.16",
		"@threlte/extras": "^9.21.0",
		"@types/node": "^25.9.3",
		"@types/three": "^0.184.1",
		"@vite-pwa/sveltekit": "^1.1.0",
		"@vitest/browser-playwright": "^4.1.8",
		"cspell": "^10.0.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"lefthook": "^2.1.9",
		"playwright": "^1.60.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"rollup-plugin-visualizer": "^7.0.1",
		"size-limit": "^12.1.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"three": "^0.184.0",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vite": "^8.0.16",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1",
		"workbox-build": "^7.4.1",
		"workbox-window": "^7.4.1",
		"wrangler": "^4.100.0",
		"@joshuafolkken/app-kit": "^0.23.0"
	},
	"packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.6.0",
			"onFail": "error"
		}
	},
	"size-limit": [
		{
			"path": ".svelte-kit/output/client/_app/immutable/**/*.js",
			"limit": "1000 kB"
		}
	]
}
