{
	"name": "simon",
	"version": "0.102.0",
	"type": "module",
	"private": true,
	"scripts": {
		"preinstall": "pnpm dlx @aikidosec/safe-chain setup-ci",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "pnpm gen && svelte-kit sync",
		"gen": "pnpm gen:pre && wrangler types",
		"gen:pre": "node -e \"const fs=require('node:fs');const d='.svelte-kit/cloudflare';if(fs.existsSync(d))fs.readdirSync(d).forEach(f=>f.startsWith('_worker.')&&fs.rmSync(d+'/'+f,{force:true}))\"",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"postinstall": "lefthook install",
		"josh": "josh",
		"size-limit": "size-limit"
	},
	"dependencies": {
		"@threlte/core": "^8.5.11",
		"@threlte/extras": "^9.15.1",
		"three": "^0.184.0"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@joshuafolkken/kit": "^0.132.0",
		"@playwright/test": "^1.59.1",
		"@size-limit/file": "^12.1.0",
		"@size-limit/preset-app": "^12.1.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.59.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.4",
		"@types/node": "^25.6.0",
		"@types/three": "^0.184.0",
		"@vite-pwa/sveltekit": "^1.1.0",
		"@vitest/browser-playwright": "^4.1.5",
		"cspell": "^10.0.0",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"lefthook": "^2.1.6",
		"playwright": "^1.59.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"rollup-plugin-visualizer": "^7.0.1",
		"size-limit": "^12.1.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.7",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.10",
		"vite-plugin-pwa": "^1.2.0",
		"vitest": "^4.1.5",
		"vitest-browser-svelte": "^2.1.1",
		"wrangler": "^4.87.0"
	},
	"packageManager": "pnpm@10.33.3+sha512.a19744364a7e248b92657a4ca5973f9354d21caf982579674b1c539f32c7420c47138ad8b1254df07aba9bc782d9b3029e3db34d5dbff974326eb74dac8ff489",
	"size-limit": [
		{
			"path": ".svelte-kit/output/client/_app/immutable/**/*.js",
			"limit": "1000 kB"
		}
	],
	"pnpm": {
		"overrides": {
			"cookie": "^0.7.0",
			"serialize-javascript": ">=7.0.5"
		},
		"onlyBuiltDependencies": [
			"sharp",
			"workerd",
			"esbuild"
		],
		"ignoredBuiltDependencies": [
			"@joshuafolkken/kit",
			"lefthook"
		]
	}
}
